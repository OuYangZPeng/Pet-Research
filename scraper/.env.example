# Copy to .env and fill in. Never commit .env to source control.

# --- Pick ONE of the following Amazon data paths ---

# Path A (recommended for free-tier verification):
# Rainforest API — sign up at https://rainforestapi.com, 100 requests/month free.
# Returns rating + ratings_total + price + BSR by ASIN or product title.
RAINFOREST_API_KEY=

# Path B: Amazon Product Advertising API (for Associate / high-volume use)
AMAZON_PAAPI_ACCESS_KEY=
AMAZON_PAAPI_SECRET_KEY=
AMAZON_PAAPI_PARTNER_TAG=
AMAZON_PAAPI_REGION=us-east-1

# Path C: Self-hosted Playwright + residential proxy fallback
AMAZON_PROXY_URL=

# YouTube Data API v3 — get from Google Cloud Console (free quota 10K units/day)
YOUTUBE_API_KEY=

# Cursor SDK — uses your existing Cursor subscription, no extra LLM key needed.
# Get key at https://cursor.com/dashboard/integrations
# If set, scraper/refresh_reviews.py auto-generates pros/cons via Agent.prompt
# instead of queueing to scraper/_insights_pending.md for manual Cursor IDE handling.
CURSOR_API_KEY=
# Default model for review insights (pure JSON synthesis). Benchmarks ~4s/SKU.
# Alternatives: claude-haiku-4-5 (~5s), gpt-5.4-nano (~7s), composer-2.5 (~9s, heaviest)
CURSOR_MODEL=gemini-3-flash

# Reddit API via PRAW — get from https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT="shadowmeta/0.1 by u/your_username"

# Output paths (relative to scraper/)
OUTPUT_DIR=../web/public/data
